\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{jougraduateheadings}[2026/03/10 Shared heading system for JOU graduate thesis]

\newlength{\jouHeadingChapterNumberWidth}
\setlength{\jouHeadingChapterNumberWidth}{1.6em}
\newlength{\jouHeadingSectionNumberWidth}
\setlength{\jouHeadingSectionNumberWidth}{2.9em}
\newlength{\jouHeadingSubsectionNumberWidth}
\setlength{\jouHeadingSubsectionNumberWidth}{4.2em}
\newlength{\jouHeadingHeaderPageBoxWidth}
\setlength{\jouHeadingHeaderPageBoxWidth}{1.8em}

\newcommand{\JOUHeadingBodyHeaderLeftInline}{江苏海洋大学硕士学位论文}
\newcommand{\JOUHeadingBodyHeaderRight}[1]{%
    第\makebox[\jouHeadingHeaderPageBoxWidth][c]{#1}页%
}
\newcommand{\JOUMakeGraduateHeader}[2]{%
    \makebox[#1][c]{%
        \kaishu\zihao{5}%
        \begin{tabular*}{#1}{@{}l@{\extracolsep{\fill}}r@{}}
            \JOUHeadingBodyHeaderLeftInline & #2
        \end{tabular*}%
    }%
}

\newcommand{\JOUTocTitle}{目\hspace{2em}录}

\newcommand{\JOUHeadingChapterLabel}[1]{%
    \makebox[\jouHeadingChapterNumberWidth][l]{#1}%
}
\newcommand{\JOUHeadingSectionLabel}[1]{%
    \makebox[\jouHeadingSectionNumberWidth][l]{#1}%
}
\newcommand{\JOUHeadingSubsectionLabel}[1]{%
    \makebox[\jouHeadingSubsectionNumberWidth][l]{#1}%
}

\newcommand{\JOUBackmatterHeadingOnly}[1]{%
    \clearpage
    \phantomsection
    \markboth{}{}%
    \thispagestyle{frontmatterstyle}%
    {\centering\JOUHeadingHei\bfseries\zihao{-2}#1\par}%
    \vspace{0.5\baselineskip}%
}

\newcommand{\JOUBackmatterChapter}[1]{%
    \JOUBackmatterHeadingOnly{#1}%
    \addcontentsline{toc}{chapter}{#1}%
}

\newcommand{\JOUApplyBodySectioning}{%
    \renewcommand{\thechapter}{\arabic{chapter}}%
    \renewcommand{\thesection}{\thechapter.\arabic{section}}%
    \renewcommand{\thesubsection}{\thesection.\arabic{subsection}}%
    \ctexset{%
        chapter={%
            format={\JOUHeadingHei\bfseries\zihao{-2}\raggedright},%
            name={,},%
            number={\arabic{chapter}},%
            aftername=\hspace{1em},%
            beforeskip=0.5\baselineskip,%
            afterskip=0.5\baselineskip%
        },%
        section={%
            format={\JOUHeadingHei\zihao{-3}},%
            beforeskip=0.5\baselineskip,%
            afterskip=0.5\baselineskip,%
            indent=0pt%
        },%
        subsection={%
            format={\JOUHeadingHei\zihao{4}},%
            beforeskip=0.5\baselineskip,%
            afterskip=0.5\baselineskip,%
            indent=0pt%
        }%
    }%
}

\newcommand{\JOUApplyBodyTextLayout}{%
    \ctexset{%
        punct=quanjiao,%
        space=auto,%
        autoindent=true%
    }%
    \setlength{\parindent}{2em}%
}

\newcommand{\JOUApplyBodyReferenceNames}{%
    \crefname{figure}{图}{图}%
    \Crefname{figure}{图}{图}%
    \crefname{table}{表}{表}%
    \Crefname{table}{表}{表}%
    \crefname{equation}{式}{式}%
    \Crefname{equation}{式}{式}%
    \crefname{chapter}{第}{第}%
    \Crefname{chapter}{第}{第}%
    \crefname{section}{节}{节}%
    \Crefname{section}{节}{节}%
    \crefname{subsection}{小节}{小节}%
    \Crefname{subsection}{小节}{小节}%
    \crefname{lstlisting}{代码}{代码}%
    \Crefname{lstlisting}{代码}{代码}%
    \crefformat{chapter}{第##2##1##3章}%
    \Crefformat{chapter}{第##2##1##3章}%
    \crefformat{section}{##2##1##3节}%
    \Crefformat{section}{##2##1##3节}%
    \crefformat{subsection}{##2##1##3小节}%
    \Crefformat{subsection}{##2##1##3小节}%
}

\newcommand{\JOUApplyBodyTocLayout}{%
    \renewcommand{\contentsname}{\JOUTocTitle}%
    \setcounter{tocdepth}{1}%
    \contentsmargin{0pt}%
    \titlecontents{chapter}[0pt]{\songti\zihao{-4}}%
        {\contentslabel{3.2em}}{}%
        {\titlerule*[0.5pc]{.}\contentspage}%
    \titlecontents{section}[2.8em]{\songti\zihao{-4}}%
        {\contentslabel{3.4em}}{}%
        {\titlerule*[0.5pc]{.}\contentspage}%
    \titlecontents{figure}[0pt]{\songti\zihao{5}}%
        {\contentslabel{6.2em}}{}%
        {\titlerule*[0.5pc]{.}\contentspage}%
    \titlecontents{table}[0pt]{\songti\zihao{5}}%
        {\contentslabel{6.2em}}{}%
        {\titlerule*[0.5pc]{.}\contentspage}%
}

\endinput
