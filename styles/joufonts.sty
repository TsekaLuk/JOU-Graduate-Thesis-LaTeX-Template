        \jou@setupproprietarycjk
        \jou@cjkconfiguredtrue
    }{}%

    \ifjou@cjkconfigured\else
        \IfFileExists{\JOUWindowsFontDir/simsun.ttc}{%
            \jou@setupwindowscjk
            \jou@cjkconfiguredtrue
        }{}%
