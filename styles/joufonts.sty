\newcommand{\jou@resolveproprietarycjkfilenames}{%
    \IfFileExists{\JOUProprietaryFontDir/SimSun.ttf}{}{%
        \IfFileExists{\JOUProprietaryFontDir/SimSun.ttc}{%
            \renewcommand{\JOUProprietarySimSunFile}{SimSun.ttc}%
        }{%
            \IfFileExists{\JOUProprietaryFontDir/宋体.ttc}{%
                \renewcommand{\JOUProprietarySimSunFile}{宋体.ttc}%
            }{}%
        }%
    }%
    \IfFileExists{\JOUProprietaryFontDir/SimHei.ttf}{}{%
        \IfFileExists{\JOUProprietaryFontDir/黑体.ttf}{%
            \renewcommand{\JOUProprietarySimHeiFile}{黑体.ttf}%
        }{}%
    }%
    \IfFileExists{\JOUProprietaryFontDir/KaiTi_GB2312.ttf}{}{%
        \IfFileExists{\JOUProprietaryFontDir/KaiTi.ttf}{%
            \renewcommand{\JOUProprietaryKaiTiFile}{KaiTi.ttf}%
        }{%
            \IfFileExists{\JOUProprietaryFontDir/楷体.ttf}{%
                \renewcommand{\JOUProprietaryKaiTiFile}{楷体.ttf}%
            }{}%
        }%
    }%
    \IfFileExists{\JOUProprietaryFontDir/FangSong_GB2312.ttf}{}{%
        \IfFileExists{\JOUProprietaryFontDir/FangSong.ttf}{%
            \renewcommand{\JOUProprietaryFangSongFile}{FangSong.ttf}%
        }{%
            \IfFileExists{\JOUProprietaryFontDir/仿宋_GB2312.ttf}{%
                \renewcommand{\JOUProprietaryFangSongFile}{仿宋_GB2312.ttf}%
            }{}%
        }%
    }%
    \IfFileExists{\JOUProprietaryFontDir/FangZhengXiaoBiaoSongJianTi.ttf}{}{%
        \IfFileExists{\JOUProprietaryFontDir/方正小标宋简.ttf}{%
            \renewcommand{\JOUProprietaryXiaoBiaoSongFile}{方正小标宋简.ttf}%
        }{}%
    }%
    \IfFileExists{\JOUProprietaryFontDir/STXingkai.ttf}{}{%
        \IfFileExists{\JOUProprietaryFontDir/华文行楷.ttf}{%
            \renewcommand{\JOUProprietaryXingkaiFile}{华文行楷.ttf}%
        }{}%
    }%
    \IfFileExists{\JOUProprietaryFontDir/STLiti.ttf}{}{%
        \IfFileExists{\JOUProprietaryFontDir/华文隶书.ttf}{%
            \renewcommand{\JOUProprietaryLishuFile}{华文隶书.ttf}%
        }{}%
    }%
}

