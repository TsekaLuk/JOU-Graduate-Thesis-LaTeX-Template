            \IfFontExistsTF{FangSong_GB2312}{%
                \setCJKfamilyfont{zhfs}[
                    BoldFont=FangSong_GB2312,
                    ItalicFont=FangSong_GB2312,
                    BoldItalicFont=FangSong_GB2312
                ]{FangSong_GB2312}%
            }{%
                \IfFontExistsTF{FangSong}{%
                    \setCJKfamilyfont{zhfs}[
                        BoldFont=FangSong,
                        ItalicFont=FangSong,
                        BoldItalicFont=FangSong
