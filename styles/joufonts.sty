            \IfFontExistsTF{FZXiaoBiaoSong-B05}{%
                \newCJKfontfamily\JOUXiaobiaoSong{FZXiaoBiaoSong-B05}%
            }{%
                \jou@usefallbackxiaobiaosong
            }%
            \IfFontExistsTF{STXingkai}{%
                \newCJKfontfamily\JOUXingkai{STXingkai}%
            }{%
                \jou@usefallbackxingkai
            }%
            \jou@usefallbacklishu
            \jou@cjkconfiguredtrue
        }{}%
    \fi

    \ifjou@cjkconfigured\else
        \IfFontExistsTF{STSong}{%
            \renewcommand{\JOUFontMode}{system-licensed}%
            \setCJKmainfont[
                BoldFont=STSong,
                ItalicFont=STSong,
                BoldItalicFont=STSong
            ]{STSong}%
            \setCJKfamilyfont{zhsong}[
                BoldFont=STSong,
                ItalicFont=STSong,
                BoldItalicFont=STSong
            ]{STSong}%
            \setCJKmonofont[
                BoldFont=STSong,
                ItalicFont=STSong,
                BoldItalicFont=STSong
            ]{STSong}%
            \IfFontExistsTF{STHeiti}{%
                \setCJKsansfont[BoldFont=STHeiti]{STHeiti}%
                \setCJKfamilyfont{zhhei}[BoldFont=STHeiti]{STHeiti}%
                \newCJKfontfamily\JOUCoverHei[
                    AutoFakeBold=\JOUCoverHeiFakeBold
                ]{STHeiti}%
            }{%
                \jou@usefallbackhei
            }%
            \IfFontExistsTF{STKaiti}{%
                \setCJKfamilyfont{zhkai}[
                    BoldFont=STKaiti,
                    ItalicFont=STKaiti,
                    BoldItalicFont=STKaiti
                ]{STKaiti}%
